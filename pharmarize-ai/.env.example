# Pharmarize.ai Environment Configuration
# Copy this to .env and adjust as needed

# Model Configuration
MODEL_NAME=indobenchmark/indobert-base-p1
MODEL_PATH=./models/pharmarize_qa_model
MAX_SEQ_LENGTH=384

# Training Configuration
BATCH_SIZE=8
LEARNING_RATE=2e-5
EPOCHS=3
WARMUP_STEPS=100
WEIGHT_DECAY=0.01

# Data Configuration
DATA_PATH=./data/processed
TRAIN_DATA=./data/qa_dataset.json
PLANT_DICTIONARY=./data/plant_dictionary.json

# Hardware Configuration
USE_GPU=false
DEVICE=cpu
NUM_WORKERS=4

# API Configuration
PORT=5000
DEBUG=false
SECRET_KEY=your-secret-key-here

# Logging
LOG_LEVEL=INFO
LOG_FILE=./results/training.log

# Output Configuration
RESULTS_PATH=./results
SAVE_TOTAL_LIMIT=3
CHECKPOINT_DIR=./models/checkpoints
